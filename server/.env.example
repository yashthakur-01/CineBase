# MongoDB Connection
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/

# TMDB API Key (get from https://www.themoviedb.org/settings/api)
TMDB_API=your_tmdb_api_key_here

# Cohere API Key (get from https://dashboard.cohere.com/api-keys)
COHERE_API=your_cohere_api_key_here

# Pinecone Configuration
# Create a dense index with metric=cosine and dimension=1536 for Cohere embed-v4.0 default output
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=movies
# Recommended: copy the index host from the Pinecone console. Example: movies-abc1234.svc.us-east-1-aws.pinecone.io
PINECONE_INDEX_HOST=
# Optional: defaults to __default__
PINECONE_NAMESPACE=movies
# Optional: pinned to the latest stable Pinecone API version used by this app
PINECONE_API_VERSION=2025-10

# Auth Secret (generate with: openssl rand -base64 32)
AUTH_SECRET=your_auth_secret_here

# Server Configuration
CLIENT_ORIGIN=http://localhost:5173
PORT=3000

# Google OAuth (get from https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
